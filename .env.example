# --- Database (Supabase Postgres) ---
# DATABASE_URL must use the POOLED connection on serverless hosts (Vercel, Lambda).
# Find both at: Supabase Dashboard → Project Settings → Database → Connection string.
#
# Pooled (Transaction mode, port 6543) — used by the app at runtime.
DATABASE_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct (port 5432) — used by Prisma for migrations only.
DIRECT_URL="postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# --- Supabase Auth (browser-safe) ---
# Currently unused (we use a static admin/admin demo login) but kept for future re-introduction.
NEXT_PUBLIC_SUPABASE_URL="https://<project-ref>.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="<anon-public-key>"

# --- App ---
# Set this to your production URL (e.g. https://roofmate.vercel.app) on Vercel.
NEXT_PUBLIC_APP_URL="http://localhost:3000"
